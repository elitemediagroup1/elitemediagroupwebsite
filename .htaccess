RewriteEngine On
RewriteBase /

# Redirect requests for the .html file directly to the clean URL (avoids duplicate content)
RewriteCond %{THE_REQUEST} \s/+(.+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Redirect index.html specifically to the site root
RewriteCond %{THE_REQUEST} \s/+(.*)index\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Internally serve the .html file for a clean-URL request, without changing the visible URL
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]

# Trailing slash on the root still resolves to index.html
DirectoryIndex index.html
